    "error": {
        "description": "【报错处理】",
        "type": "object",
        "hint": "全局拦截报错",
        "items": {
            "keywords": {
                "description": "检测报错所用关键词",
                "hint": "当 Bot 消息包含列表中任一关键词时，将触发拦截",
                "type": "list",
                "default": [
                    "请求失败",
                    "出现异常"
                ]
            },
            "custom_msg": {
                "description": "原对话的消息",
                "hint": "当报错被拦截时，会在原对话中发送此消息。留空则不发送",
                "type": "string",
                "default": ""
            },
            "forward_umo": {
                "description": "转发目标会话 ID",
                "hint": "将报错信息转发到该会话。可用 sid 命令查看当前会话 ID。填 admin 表示转发给配置中的所有 Bot 管理员；留空则不转发",
                "type": "string",
                "default": "admin"
            }
        }
    },
    "block": {
        "description": "【消息拦截】",
        "type": "object",
        "hint": "根据各种条件对消息进行拦截",
        "items": {
            "timeout": {
                "description": "超时拦截秒数",
                "hint": "若 Bot 回复耗时超过该阈值（秒），则判定为超时并拦截该消息。可缓解 LLM 响应过慢导致的“错位回复”问题",
                "type": "int",
                "slider": {
                    "min": 0,
                    "max": 180,
                    "step": 1
                },
                "default": 0
            },
            "block_reread": {
                "description": "拦截流口水的消息",
