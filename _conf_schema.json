    "at": {
        "description": "【解析艾特】",
        "type": "object",
        "hint": "将消息句首的假艾特转换为真实艾特，并按概率决定保留或移除",
        "default": true,
        "items": {
            "at_str": {
                "description": "转换成字符串艾特",
                "hint": "将解析到的真实艾特转换回字符串形式（如 @username xxx）。若出现艾特与文本间空格丢失，可尝试开启",
                "type": "bool",
                "default": true
            },
            "at_prob": {
                "description": "艾特概率",
                "hint": "随机值小于该值时强制带 @，大于该值时强制不带 @。设为 0 表示关闭该功能。建议先关闭 AstrBot 自带的 At 功能",
                "type": "float",
                "slider": {
                    "min": 0,
                    "max": 1,
                    "step": 0.01
                },
                "default": 0.1
            }
        }
    },
    "clean": {
        "description": "【文本清理】",
        "type": "object",
        "hint": "清理文本。注意清洗顺序：中括号内容 -> 小括号内容 -> 情绪标签 -> emoji -> 句首字符 -> 句尾字符 -> 整体清洗特殊符号",
        "items": {
            "text_threshold": {
                "description": "文本清理长度阈值",
                "hint": "多少个字符以下时执行文本清理，可以防止对长文本误清理，设为 0 则不执行文本清理",
                "type": "int",
                "slider": {
                    "min": 0,
                    "max": 1000,
                    "step": 50
                },
                "default": 150
            },
            "bracket": {
                "description": "摘除中括号内容",
                "hint": "即摘除消息中的 [...] ",
                "type": "bool",
                "default": true
            },
            "parenthesis": {
                "description": "摘除小括号内容",
                "hint": "摘除消息中的 (...) 内容，支持半角与全角括号",
                "type": "bool",
                "default": true
            },
            "emotion_tag": {
                "description": "摘除情绪标签",
                "hint": "摘除消息中的 &&...&& 内容；若不生效，可能被其他插件干扰",
                "type": "bool",
                "default": true
            },
            "emoji": {
                "description": "清理 Emoji",
                "hint": "清理文本中的 Emoji，对高频使用 Emoji 的模型效果更明显（如部分智谱模型）",
                "type": "bool",
                "default": true
            },
            "lead": {
                "description": "去除句首字符",
                "hint": "对某些喜欢输出前缀的模型有奇效，注意只去除句首字符",
                "type": "list",
                "default": [
                    "print",
                    ":",
                    "："
                ]
            },
            "tail": {
                "description": "去除句尾字符",
                "hint": "对某些喜欢输出句号的模型有奇效，注意只去除句尾字符",
                "type": "list",
                "default": [
                    "。",
                    "."
                ]
            },
            "punctuation": {
                "description": "整体清洗的特殊符号",
                "hint": "填写正则表达式，例如 [#%~]。该规则会作用于整句文本",
                "type": "string",
                "default": "[#%~]"
            }
        }
    },
    "replace": {
        "description": "【文本替换】",
        "type": "object",
        "hint": "替换消息中的特定词，如一些敏感词",
        "items": {
            "words": {
                "description": "替换词对",
                "hint": "格式为“旧词 新词”：旧词在前，中间空格分隔，新词在后（新词可留空，留空时使用默认替换词）",
