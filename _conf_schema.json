        "items": {
            "threshold": {
                "description": "文本长度阈值",
                "hint": "当消息长度超过该阈值时，执行长文本转图处理",
                "type": "int",
                "slider": {
                    "min": 0,
                    "max": 1000,
                    "step": 50
                },
                "default": 150
            },
            "pillowmd_style_dir": {
                "description": "Pillowmd 样式目录",
                "hint": "支持相对路径与绝对路径，请使用 / 作为路径分隔符",
                "type": "string",
                "default": "data/plugins/astrbot_plugin_outputpro/t2i_style"
            },
            "auto_page": {
                "description": "自动分页",
                "hint": "开启后，渲染器会按照黄金分割比进行分页",
                "type": "bool",
                "default": true
            },
            "clean_cache": {
                "description": "自动清理缓存",
                "hint": "开启后，重载插件时，会自动清空图片缓存",
                "type": "bool",
                "default": true
            }
        }
    },
    "reply": {
        "description": "【智能引用】",
        "type": "object",
        "hint": "当 Bot 准备回复的消息被他人插入新消息时，自动引用目标消息",
        "items": {
            "threshold": {
                "description": "引用阈值",
                "hint": "设置“被插入多少条消息后触发引用”。设为 0 表示关闭引用功能。建议先关闭 AstrBot 自带 Reply 功能",
                "type": "int",
                "slider": {
                    "min": 0,
                    "max": 4,
                    "step": 1
                },
                "default": 1
            },
            "queue_maxlen": {
                "description": "消息追踪窗口",
                "hint": "智能引用会在群消息追踪窗口内寻找原触发消息。群越活跃、模型回复越慢，建议调大；窗口太小会导致原消息被挤出后跳过引用。默认 200。",
                "type": "int",
                "slider": {
                    "min": 20,
                    "max": 1000,
                    "step": 20
                },
                "default": 200
            },
            "include_at": {
                "description": "引用时包含艾特",
                "hint": "开启后，在引用回复的同时会艾特被回复的人",
                "type": "bool",
                "default": false
            }
        }
    },
    "forward": {
        "description": "【合并转发】",
        "hint": "将长文本合并转发（aiocqhttp 平台为合并转发，Telegram 平台为折叠引用）",
        "type": "object",
        "items": {
            "threshold": {
                "description": "文本长度阈值",
                "hint": "转发长度超过此阈值时执行转发操作",
                "type": "int",
                "slider": {
                    "min": 0,
                    "max": 1000,
                    "step": 50
                },
                "default": 150
            },
            "node_name": {
                "description": "转发节点昵称",
                "hint": "转发消息时使用的昵称。留空则自动使用 Bot 当前昵称",
                "type": "string",
                "default": ""
            },
            "node_max_length": {
                "description": "单个转发节点目标长度",
                "hint": "合并转发内每条聊天记录节点期望容纳的文本长度。达到该长度后会优先寻找附近的句号、换行等自然断点，避免一句话被切得太碎。",
                "type": "int",
                "slider": {
                    "min": 100,
                    "max": 3000,
                    "step": 50
                },
                "default": 1000
            },
            "node_hard_limit": {
                "description": "单个转发节点硬上限",
                "hint": "合并转发内单个节点的最大文本长度。超过后一定会强制切开，用来避开 QQ/NapCat 对单条转发节点的隐藏限制。",
                "type": "int",
                "slider": {
                    "min": 100,
                    "max": 3000,
                    "step": 50
                },
                "default": 1200
            }
        }
    },
    "recall": {
        "description": "【自动撤回】",
        "hint": "检测发出的消息是否需要撤回，并按延时执行撤回（当前支持 aiocqhttp 与 Telegram）",
        "type": "object",
        "items": {
            "keywords": {
                "description": "触发撤回的关键词",
                "hint": "消息中含有这些关键词时触发自动撤回操作",
                "type": "list",
                "default": [
                    "我是",
                    "我叫",
                    "我住在"
                ]
            },
            "delay": {
                "description": "撤回延时",
                "hint": "消息发送后延迟多少秒执行撤回",
                "type": "int",
                "slider": {
                    "min": 0,
                    "max": 110,
                    "step": 1
                },
                "default": 30
            }
        }
    },
    "split": {
        "description": "【分段回复】",
        "hint": "将一条长消息按智能分段逻辑拆分为多段后依次发送",
        "type": "object",
        "items": {
            "max_length": {
                "description": "分段字数上限",
                "hint": "消息字数超过该值时不进行分段；设为 0 表示不限制",
                "type": "int",
                "slider": {
                    "min": 0,
                    "max": 600,
                    "step": 1
                },
                "default": 200
            },
            "max_count": {
                "description": "最大分段数",
                "hint": "此处设定每句消息最多可以分成多少段话来发送",
                "type": "int",
                "slider": {
                    "min": 1,
                    "max": 5,
                    "step": 1
                },
                "default": 2
            },
            "char_list": {
                "description": "触发分段的字符",
                "hint": "文字后面带这些符号就会分段，优先采用排在前面的分段符来分段。分段符示例：。？！\\n \\s（换行是\\n，空格是\\s）。注意：括号/引号等成对符号内部不会触发分段",
                "type": "list",
                "default": [
                    "。",
                    "？",
                    "\\n",
                    "，"
                ]
            },
            "per_char_delay": {
                "description": "打字速度",
                "hint": "每段话之间需要停顿一定时间，用来模拟打字，此处设定每个汉字耗时多少秒（英文字母视为半个汉字）",
                "type": "float",
                "slider": {
                    "min": 0.1,
                    "max": 1,
                    "step": 0.01
                },
                "default": 0.3
            },
            "delay_scope_str": {
                "description": "停顿时间范围",
                "hint": "设定每段话之间停顿的时间范围，用来防止短句停顿太短，长句停顿太长。单位为秒，用~分隔",
                "type": "string",
                "default": "1~16"
            },
            "show_typing": {
                "description": "显示正在输入中",
                "hint": "开启后，打字时会显示“正在输入中...”的状态。仅支持 aiocqhttp、telegram、weixin_oc 消息平台, 其他平台无效",
                "type": "bool",
                "default": true
            },
            "tail_punc": {
                "description": "要清理的句尾标点",
                "hint": "分段后要清理每句话的句尾标点，此处定义哪些标点需要清理",
                "type": "list",
                "default": [
                    ".",
                    ",",
                    "，",
                    "。",
                    ";",
                    "；",
                    ":",
                    "：",
                    "、"
                ]
            }
        }
    }
}
